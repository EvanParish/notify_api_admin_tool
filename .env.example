# Required: encryption key for stored secrets (use a long random string)
MASTER_KEY=replace_with_a_secure_random_string

# Set to false to connect to real VA Notify API (configure credentials in Settings page)
USE_MOCK_API=false

# API host URLs per environment (JSON object, single line)
API_PUBLIC_HOSTS='{"dev":"https://dev-api.va.gov/vanotify","perf":"https://sandbox-api.va.gov/vanotify","staging":"https://staging-api.va.gov/vanotify","prod":"https://api.va.gov/vanotify"}'

# Local database path (overridden by docker-compose.yml when using Docker)
DATABASE_PATH=data/app.db

# Docker networking: when running in Docker, the CONTAINER_HOST env var (set
# automatically by docker-compose.yml) remaps localhost/127.0.0.1 URLs in
# API_PUBLIC_HOSTS to host.docker.internal so the container can reach services
# running on the host machine. No manual URL changes needed.
